{
  "manifest_version": 3,
  "name": "LLM Tab Context Exporter",
  "version": "0.1.0",
  "description": "Export open browser tabs into LLM-readable Markdown.",
  "permissions": ["tabs", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
